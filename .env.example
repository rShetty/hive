# Deployment Configuration
# Copy this file to .env and fill in your values

# Required: Encryption key for sensitive data (use: openssl rand -hex 32)
ENCRYPTION_KEY=your-encryption-key-here

# Required: Secret key for JWT tokens (use: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Optional: Git branch to deploy (default: main)
GIT_BRANCH=main

# Optional: Remote host (default set in deploy.sh)
# REMOTE_HOST=root@187.127.140.125

# Optional: Remote port (default: 8080)
# REMOTE_PORT=8080

# ── OpenClaw agent deployment ───────────────────────────────────────────────
# How OpenClaw agents are deployed when calling POST /api/agents/deploy-openclaw
#   local  → deploy on the local Docker daemon (falls back to mock if no Docker)
#   vps    → deploy to a remote VPS over SSH (requires the vars below)
#   auto   → vps when OPENCLAW_VPS_HOST + OPENCLAW_VPS_SSH_KEY_PATH are set, else local
OPENCLAW_DEPLOY_MODE=auto

# Remote VPS deployment (only needed when OPENCLAW_DEPLOY_MODE=vps or auto)
# OPENCLAW_VPS_HOST=187.127.140.125
# OPENCLAW_VPS_SSH_KEY_PATH=/path/to/ssh/key
# OPENCLAW_VPS_SSH_USER=root
# OPENCLAW_VPS_SSH_PORT=22

# Local/network settings used when deploying on the local Docker daemon
# OPENCLAW_PORT_START=9000
# HIVE_DOMAIN=hive.yourdomain.com
# HOST_IP=127.0.0.1

